# ─── DeepSeek API ───
DEEPSEEK_API_KEY=sk-xxxx

# ─── 数据库 ───
# 本地开发: localhost | Docker: mysql_db | 阿里云: 内网IP
DB_HOST=mysql_db
DB_USER=root
DB_PASSWORD=root_password
DB_NAME=geo_knowledge_engine

# ─── 微信公众号（后台→设置与开发→基本配置）───
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ─── 性能优化（禁用 OpenTelemetry 防止导入卡死）───
OTEL_SDK_DISABLED=true
MYSQL_CONNECTOR_PYTHON_TELEMETRY=0
